# Public HTTPS origin of this API. ChatGPT connects to ${HEYJULE_API_URL}/mcp.
HEYJULE_API_URL=https://api.heyjule.example
PORT=8787

# Persistent server-side database path. Use an encrypted, access-controlled
# volume with encrypted backups. A single-node SQLite deployment is suitable
# for a pilot; migrate the repository adapter to managed PostgreSQL before HA.
HEYJULE_DATABASE_PATH=./data/heyjule-api.db

# Exactly 32 random bytes, base64url encoded. Keep in KMS/secret management.
# Generate: openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
HEYJULE_DATA_KEY=

# OAuth 2.1/OIDC issuer used by both ChatGPT and the patient/doctor clients.
HEYJULE_OAUTH_ISSUER=https://auth.heyjule.example
HEYJULE_OAUTH_AUDIENCE=https://api.heyjule.example
# Optional override; defaults to ${HEYJULE_OAUTH_ISSUER}/.well-known/jwks.json
# HEYJULE_OAUTH_JWKS_URL=

# Comma-separated browser origins allowed to call REST endpoints. Native mobile
# clients do not send an Origin header.
HEYJULE_ALLOWED_ORIGINS=https://doctor.heyjule.example

# Only enable when the API accepts traffic exclusively from a trusted reverse
# proxy that overwrites Forwarded/X-Forwarded-* headers.
HEYJULE_TRUST_PROXY=false

# Server-only xAI credential used to mint five-minute Voice API client tokens.
# Never expose this value through an EXPO_PUBLIC_* variable.
XAI_API_KEY=

# Local development only. Refused when NODE_ENV=production. JSON maps random
# bearer tokens to identities/scopes; never put real patient data in dev mode.
# HEYJULE_DEV_TOKENS={"replace-with-random-token":{"sub":"patient_demo","role":"patient","scopes":["device:write","entry:write","entry:claim","patient:data:write","patient:data:read","report:write"]}}
