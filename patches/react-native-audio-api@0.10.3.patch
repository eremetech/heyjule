diff --git a/ios/audioapi/ios/system/AudioSessionManager.mm b/ios/audioapi/ios/system/AudioSessionManager.mm
index 5c22a17256c99212fb35af0913a9338087c60efc..54d8ac2c71ac335f4e3e76b3c77bbe00aa34a802 100644
--- a/ios/audioapi/ios/system/AudioSessionManager.mm
+++ b/ios/audioapi/ios/system/AudioSessionManager.mm	
@@ -153,6 +153,9 @@ - (bool)setActive:(bool)active
 
   if (success) {
     self.isActive = active;
+    if (active) {
+      [self applyOutputPortOverride];
+    }
   }
 
   if (error != nil) {
@@ -172,6 +175,8 @@ - (bool)configureAudioSession
   }
 
   if (![self hasDirtySettings]) {
+    // Still re-apply port override — AVAudioEngine start/stop often clears it.
+    [self applyOutputPortOverride];
     return true;
   }
 
@@ -201,9 +206,38 @@ - (bool)configureAudioSession
   }
 
   self.hasDirtySettings = false;
+  [self applyOutputPortOverride];
   return true;
 }
 
+- (void)applyOutputPortOverride
+{
+  if (!self.shouldManageSession) {
+    return;
+  }
+  if (self.sessionCategory != AVAudioSessionCategoryPlayAndRecord) {
+    return;
+  }
+
+  BOOL wantSpeaker = (self.sessionOptions & AVAudioSessionCategoryOptionDefaultToSpeaker) != 0;
+  AVAudioSessionPortOverride portOverride =
+      wantSpeaker ? AVAudioSessionPortOverrideSpeaker : AVAudioSessionPortOverrideNone;
+  NSError *error = nil;
+  BOOL ok = [self.audioSession overrideOutputAudioPort:portOverride error:&error];
+  if (!ok || error != nil) {
+    NSLog(
+        @"[AudioSessionManager] overrideOutputAudioPort(%@) failed: %@",
+        wantSpeaker ? @"speaker" : @"none",
+        error != nil ? [error debugDescription] : @"unknown");
+  } else {
+    NSLog(@"[AudioSessionManager] overrideOutputAudioPort -> %@", wantSpeaker ? @"SPEAKER" : @"NONE");
+  }
+
+  for (AVAudioSessionPortDescription *output in self.audioSession.currentRoute.outputs) {
+    NSLog(@"[AudioSessionManager] current output: %@ (%@)", output.portName, output.portType);
+  }
+}
+
 - (bool)reconfigureAudioSession
 {
   self.hasDirtySettings = true;
