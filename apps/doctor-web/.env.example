# Copy to .env.local and fill in. Never commit real secrets.

# 32+ chars — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
HEYJULE_API_URL=http://localhost:8787
HEYJULE_INTERNAL_API_URL=http://localhost:8787

# Optional: where the SQLite file lives (defaults to ./data/heyjule.db)
# DATABASE_PATH=

# Development-only switch for the old seeded /r/* visual prototype.
HEYJULE_ENABLE_LEGACY_REPORTS=false

# Server-only key for the report chatbot. Never use a NEXT_PUBLIC_ prefix.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# Production safety gate. Set to true only after the OpenAI project and this
# deployment are approved for the health-data workflow (including any required
# BAA and data-retention controls). Development mock data does not require it.
OPENAI_PHI_ENABLED=false
