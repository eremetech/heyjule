# Public identifiers only. Never put client secrets or server encryption keys in EXPO_PUBLIC_*.
EXPO_PUBLIC_HEYJULE_API_URL=https://api.heyjule.health
EXPO_PUBLIC_HEYJULE_OAUTH_ISSUER=https://auth.heyjule.health
EXPO_PUBLIC_HEYJULE_OAUTH_CLIENT_ID=heyjule-patient-mobile

# Current pilot mode. The fixture is visibly labeled and exercises the same
# API, model, encryption, and doctor-viewer flow as future live sources.
EXPO_PUBLIC_HEYJULE_MOCK_DATA_ENABLED=true

# Local development only; AuthProvider ignores this in production builds.
# EXPO_PUBLIC_HEYJULE_DEV_ACCESS_TOKEN=
