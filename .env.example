# Copy to .env for the root Docker Compose deployment. Never commit .env.

# Public HTTPS routes configured in Dokploy/Coolify.
HEYJULE_API_URL=https://jules.agenticsonar.com
BETTER_AUTH_URL=https://doctors.agenticsonar.com
HEYJULE_ALLOWED_ORIGINS=https://doctors.agenticsonar.com

# Generate independently:
#   openssl rand -base64 32 | tr '+/' '-_' | tr -d '=\n'
HEYJULE_DATA_KEY=
#   openssl rand -base64 48 | tr -d '\n'
BETTER_AUTH_SECRET=

# Patient OAuth/OIDC provider. Access tokens must use HEYJULE_API_URL as their
# audience and include the patient role and documented scopes.
HEYJULE_OAUTH_ISSUER=https://auth.example.com
HEYJULE_OAUTH_AUDIENCE=https://jules.agenticsonar.com
# Optional; defaults to <issuer>/.well-known/jwks.json.
HEYJULE_OAUTH_JWKS_URL=

# Structured clinical-report provider. Requests use the Responses API,
# Structured Outputs, and store=false.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# Current deterministic demo flow. This never authorizes live records: if any
# selected entry is marked live, OPENAI_PHI_ENABLED must also be true.
HEYJULE_ALLOW_MOCK_LLM=true
OPENAI_PHI_ENABLED=false

# Optional server-only key for five-minute xAI Voice API client tokens.
XAI_API_KEY=
