# Copy to .env and fill in. Never commit real secrets.

# --- Core API (services/api) ---
API_PORT=4000
DATABASE_URL=

# --- Wearables ingestion (services/wearables) ---
# Provider credentials for wearable integrations (Apple Health, Fitbit, Oura, ...)
WEARABLES_WEBHOOK_SECRET=

# --- Conversation (services/conversation) ---
# Speech-to-text + LLM providers for voice/message symptom logging
SPEECH_TO_TEXT_API_KEY=
LLM_API_KEY=

# --- Reports (services/reports) ---
REPORTS_SIGNING_SECRET=

# --- Doctor web (apps/doctor-web) ---
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Patient mobile (apps/patient-mobile) ---
EXPO_PUBLIC_API_URL=http://localhost:4000
